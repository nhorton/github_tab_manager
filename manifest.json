{
  "manifest_version": 3,
  "name": "GitHub Tab Manager",
  "description": "Keeps GitHub tabs together, sorted, de-duplicated by pull request, and labels closed or merged PR tabs.",
  "version": "0.1.0",
  "permissions": ["tabs", "windows"],
  "host_permissions": ["https://github.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
